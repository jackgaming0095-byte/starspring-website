# ---------------------------------------------------------------------------
# StarSpring environment
#
# Two kinds of configuration live here:
#
#   1. BUILD-TIME (Next).  Prefixed NEXT_PUBLIC_ and read during the build.
#      Set these in the Cloudflare build environment variables, or copy this
#      file to .env.local for local development.
#
#   2. RUNTIME (Worker).  Read at request time by src/app/api/audit/route.ts.
#      Set these in the Cloudflare dashboard under the Worker's
#      Settings -> Variables and Secrets. For local `npm run preview`, put them
#      in an untracked .dev.vars file (same KEY=value format).
#
# None are required for the site to run; every one has a safe fallback. Only
# NEXT_PUBLIC_* is ever exposed to the browser.
# ---------------------------------------------------------------------------

# --- Build-time (Next) ---------------------------------------------------
# Canonical origin. Drives metadata, canonical URLs, sitemap and robots.
# Falls back to https://starspring.example, which is a placeholder.
NEXT_PUBLIC_SITE_URL=https://starspring.example

# --- Runtime (Worker: src/app/api/audit/route.ts) ------------------------
# Where a submitted free-audit lead goes.
#   Set   -> the lead is POSTed as JSON to this URL.
#   Unset -> the route returns 503 and the form tells the visitor to email
#            instead. It never fakes a successful submission.
# Works with HubSpot, Pipedrive, Zapier, Make, n8n, a Slack workflow, or your
# own endpoint. Payload: { source: "starspring-free-audit", lead: { ... } }
LEAD_WEBHOOK_URL=

# Optional. Sent as `Authorization: Bearer <token>` with the webhook request.
# Store as a secret in production.
LEAD_WEBHOOK_TOKEN=

# Salt for the one-way hash used to bucket form submissions for rate limiting.
# Set any long random string (secret) in production. Raw IPs are never stored.
RATE_LIMIT_SALT=
