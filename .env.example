# ---------------------------------------------------------------------------
# StarSpring environment
# Copy to .env.local for development. None of these are required to run the
# site; every one has a safe fallback. Only NEXT_PUBLIC_* reaches the browser.
# ---------------------------------------------------------------------------

# Canonical origin. Used for metadata, canonical URLs, sitemap and robots.
# Falls back to https://starspring.example, which is a placeholder.
NEXT_PUBLIC_SITE_URL=https://starspring.example

# --- Lead delivery -------------------------------------------------------
# Where a submitted free-audit request goes.
#   Set     -> the lead is POSTed as JSON to this URL.
#   Unset   -> development appends to .data/leads.jsonl;
#              PRODUCTION returns a 503 and the form tells the visitor to
#              email instead. It never fakes a successful submission.
# Works with HubSpot, Pipedrive, Zapier, Make, n8n, Slack workflows or your own
# endpoint. Payload shape: { source: "starspring-free-audit", lead: { ... } }
LEAD_WEBHOOK_URL=

# Optional. Sent as `Authorization: Bearer <token>` with the webhook request.
LEAD_WEBHOOK_TOKEN=

# --- Exchange rates ------------------------------------------------------
# Optional. Without it the site uses the keyless open.er-api.com endpoint.
# Set it to use exchangerate-api.com's keyed endpoint for higher limits.
# Server-side only; never exposed to the browser.
EXCHANGE_RATE_API_KEY=

# --- Rate limiting -------------------------------------------------------
# Salt for the one-way hash used to bucket form submissions. Set any long
# random string in production so hashes are not comparable between deploys.
# Raw IP addresses are never stored or logged.
RATE_LIMIT_SALT=

# --- Local testing -------------------------------------------------------
# Forces a country code so the currency logic can be tested locally, where no
# platform geo header exists. Try GB, IN, AE, US, DE. Leave unset in production.
GEO_COUNTRY_OVERRIDE=
